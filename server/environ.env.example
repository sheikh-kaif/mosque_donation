# Copy this file to environ.env and fill in real values.
# environ.env is gitignored, so it's safe to put secrets there.

PORT=4000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret

# Email (nodemailer)
SENDER_EMAIL=your_sender_email

# --- UPI Donations (no payment gateway needed) ---
# Your real UPI ID / VPA that should receive the money, e.g. yourname@upi, 9876543210@ybl, mosque@paytm
UPI_ID=yourmosque@upi
# Name shown to the donor in their UPI app when they pay
UPI_PAYEE_NAME=FaithFund Masjid
